---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Solo Perros — Comidas Rápidas",
  description = "Las mejores comidas rápidas de Pasto. Hot dogs, hamburguesas, salchipapas y más. Pide a domicilio por WhatsApp. 🌭🍔",
} = Astro.props;

const siteUrl = "https://soloperros.com";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/images/logo.png`} />
    <link rel="canonical" href={siteUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1B3F8B" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${import.meta.env.BASE_URL}/images/logo.png`} />
    <meta property="og:locale" content="es_CO" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
