---
import { combos, formatPrice, whatsappLink } from '../data/menu';
---

<section id="combos" class="py-16 px-4 max-w-6xl mx-auto">
  <!-- Encabezado -->
  <div class="flex items-center gap-4 mb-10">
    <div class="w-1.5 h-16 rounded-full bg-[#F5A623]"></div>
    <div>
      <p class="text-gray-500 text-sm font-semibold uppercase tracking-widest">Más por menos</p>
      <h2 class="font-display text-5xl sm:text-6xl text-[#F5A623] tracking-wide leading-none">
        🍟 Combos
      </h2>
    </div>
  </div>

  <p class="text-gray-400 mb-8 -mt-4 ml-6 text-sm">
    Agrega un combo a tu pedido para completar la experiencia.
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    {combos.map((combo) => {
      const msg = `Hola Solo Perros 🌭 quiero agregar un combo: *${combo.includes.join(' + ')}* — ${formatPrice(combo.price)}`;
      return (
        <article class="card-hover bg-[#1a2340] border border-[#F5A623]/20 rounded-2xl overflow-hidden flex flex-col sm:flex-row">
          <!-- Imagen -->
          <div class="sm:w-40 aspect-video sm:aspect-auto flex-shrink-0 overflow-hidden bg-[#0D1B3E]">
            <img
              src={combo.image}
              alt={combo.includes[0]}
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Contenido -->
          <div class="flex flex-col p-5 gap-3 flex-1">
            <div class="flex items-start justify-between gap-2">
              <ul class="space-y-1">
                {combo.includes.map((inc) => (
                  <li class="flex items-center gap-2 text-gray-300 text-sm">
                    <span class="text-[#F5A623]">✓</span> {inc}
                  </li>
                ))}
              </ul>
              <span class="text-[#F5A623] font-bold text-2xl font-display flex-shrink-0">
                {formatPrice(combo.price)}
              </span>
            </div>
            <a
              href={whatsappLink(msg)}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-auto flex items-center justify-center gap-2 bg-[#F5A623] hover:bg-[#F07D00] text-[#0D1B3E] text-sm font-bold py-2 rounded-xl transition-colors"
            >
              Agregar combo
            </a>
          </div>
        </article>
      );
    })}
  </div>
</section>
